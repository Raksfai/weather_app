msgid "Atmos — Weather"
msgstr "Atmos — Погода"

msgid "Favorites"
msgstr "Обране"

msgid "Compare"
msgstr "Порівняти"

msgid "Language"
msgstr "Мова"

msgid "Search city..."
msgstr "Пошук міста..."

msgid "Go"
msgstr "Пошук"

msgid "Add to favorites"
msgstr "Додати в обране"

msgid "Add to compare"
msgstr "Додати до порівняння"

msgid "Feels like"
msgstr "Відчувається як"

msgid "Humidity"
msgstr "Вологість"

msgid "Pressure"
msgstr "Тиск"

msgid "Today Details"
msgstr "Деталі сьогодні"

msgid "Temperature & humidity"
msgstr "Температура і вологість"

msgid "Temperature"
msgstr "Температура"

msgid "5-Day Forecast"
msgstr "Прогноз на 5 днів"

msgid "Enter a city to see the weather"
msgstr "Введіть місто, щоб побачити погоду"

msgid "City comparison"
msgstr "Порівняння міст"

msgid "Select at least two cities"
msgstr "Оберіть щонайменше два міста"

msgid "Close compare modal"
msgstr "Закрити вікно порівняння"

msgid "City"
msgstr "Місто"

msgid "Temp"
msgstr "Темп."

msgid "Weather"
msgstr "Погода"

msgid "Add at least two cities to compare."
msgstr "Додайте щонайменше два міста для порівняння."

msgid "⚖️ Add to compare"
msgstr "⚖️ Додати до порівняння"

msgid "City wasn't found"
msgstr "Місто не знайдено"

msgid "Weather service is unavailable"
msgstr "Сервіс погоди недоступний"

msgid "No cities provided"
msgstr "Міста не вказані"

msgid "Weather chart for %(date)s"
msgstr "Графік погоди на %(date)s"

msgid "✓ In compare"
msgstr "✓ У порівнянні"

msgid "Loading comparison..."
msgstr "Завантаження порівняння..."

msgid "Maximum 5 cities. Remove one to add another."
msgstr "Максимум 5 міст. Видаліть одне, щоб додати інше."

msgid "No favorites yet."
msgstr "Обраних міст ще немає."

msgid "Remove"
msgstr "Видалити"

msgid "selected"
msgstr "обрано"

msgid "Comparison is unavailable."
msgstr "Порівняння недоступне."

msgid "Outfit advice"
msgstr "Порада щодо одягу"

msgid "Bundle up"
msgstr "Одягніться дуже тепло"

msgid "Freezing conditions call for serious insulation."
msgstr "Морозна погода потребує серйозного утеплення."

msgid "Wear a heavy winter coat."
msgstr "Одягніть теплу зимову куртку."

msgid "Add a warm hat, scarf, and gloves."
msgstr "Додайте теплу шапку, шарф і рукавички."

msgid "Choose insulated footwear."
msgstr "Оберіть утеплене взуття."

msgid "Dress warm"
msgstr "Одягніться тепло"

msgid "It will feel cold, so keep a warm outer layer ready."
msgstr "Буде відчутно холодно, тож потрібен теплий верхній шар."

msgid "Wear a warm coat."
msgstr "Одягніть тепле пальто або куртку."

msgid "Use a sweater or hoodie as a middle layer."
msgstr "Використайте светр або худі як середній шар."

msgid "Choose closed shoes."
msgstr "Оберіть закрите взуття."

msgid "Use a light jacket"
msgstr "Візьміть легку куртку"

msgid "Mild but cool weather is best handled with layers."
msgstr "Помірно прохолодну погоду найкраще проходити шарами."

msgid "Wear a jacket or sweater."
msgstr "Одягніть куртку або светр."

msgid "Keep a removable layer for changing conditions."
msgstr "Майте шар, який легко зняти при зміні погоди."

msgid "Long pants will feel more comfortable."
msgstr "Довгі штани будуть комфортнішими."

msgid "Keep it light"
msgstr "Одягайтесь легко"

msgid "Comfortable weather, but a light layer may still help."
msgstr "Погода комфортна, але легкий шар може знадобитися."

msgid "Wear a light layer or long-sleeve shirt."
msgstr "Одягніть легкий шар або сорочку з довгим рукавом."

msgid "Comfortable everyday shoes are enough."
msgstr "Зручного повсякденного взуття достатньо."

msgid "Carry a thin jacket if you will be out late."
msgstr "Візьміть тонку куртку, якщо будете надворі пізно."

msgid "Stay cool"
msgstr "Не перегрівайтесь"

msgid "Warm weather favors light, breathable clothing."
msgstr "У теплу погоду краще легкий дихаючий одяг."

msgid "Wear light breathable clothes."
msgstr "Одягніть легкий дихаючий одяг."

msgid "Choose comfortable light shoes."
msgstr "Оберіть зручне легке взуття."

msgid "Take water if you will be outside for a while."
msgstr "Візьміть воду, якщо будете надворі довго."

msgid "Add a waterproof outer layer."
msgstr "Додайте водонепроникний верхній шар."

msgid "Take an umbrella and avoid exposed routes."
msgstr "Візьміть парасольку й уникайте відкритих маршрутів."

msgid "Take an umbrella."
msgstr "Візьміть парасольку."

msgid "Wear a waterproof jacket or shoes."
msgstr "Одягніть водонепроникну куртку або взуття."

msgid "Wear warm waterproof boots."
msgstr "Одягніть теплі водонепроникні черевики."

msgid "Use gloves for extra warmth."
msgstr "Використайте рукавички для додаткового тепла."

msgid "Use breathable layers because damp air can feel colder."
msgstr "Обирайте дихаючі шари, бо вологе повітря може відчуватися холоднішим."

msgid "Prefer breathable fabrics and keep water nearby."
msgstr "Віддайте перевагу дихаючим тканинам і тримайте воду поруч."
